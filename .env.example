# Aurey - sample environment (copy to `.env` and fill in).
# Pydantic reads `AUREY_*` vars; see `src/aurey/settings/`.

# Hosted control-plane (requires Postgres DATABASE_URL / AUREY_DATABASE_URL).
# AUREY_HOSTED_PLATFORM_ENABLED=false
# Synthetic email domain for Platform user upserts (default hosted-aurey.local).
# AUREY_HOSTED_SYNTHETIC_EMAIL_DOMAIN=hosted-aurey.local

# Hosted / 1Claw Platform (provision apps, templates, operator runtime).
# Platform API key (plt_…) — literal secret in env:
# AUREY_PLATFORM_API_KEY=
# Optional: app identifier for paths / logging.
# AUREY_PLATFORM_APP_ID=
# Template id from bootstrap / Platform provisioning:
# AUREY_PLATFORM_TEMPLATE_ID=
# Operator vault + agent (ocv_ / control plane); vault may stay empty until provisioned.
# AUREY_OPERATOR_VAULT_ID=
# AUREY_OPERATOR_AGENT_ID=
# Operator agent API key: value lives in the env var *named* below (default name shown).
# AUREY_OPERATOR_AGENT_API_KEY=
# AUREY_OPERATOR_AGENT_API_KEY_SECRET_SOURCE=AUREY_OPERATOR_AGENT_API_KEY
# Scope string for 1Claw intents delegation (placeholder — align with your Platform app).
# AUREY_ONECLAW_DELEGATED_TOKEN_SCOPE=1claw:intents:delegated
# Phase B OIDC placeholders (optional):
# AUREY_HOSTED_OIDC_ISSUER_URL=
# AUREY_HOSTED_OIDC_AUDIENCE=
# AUREY_HOSTED_OIDC_SUBJECT_TOKEN_TTL_SECONDS=300

# Required for production `bootstrap_aurey_service_state`:
AUREY_ONECLAW_VAULT_ID=
# API key value goes in the env var *named* below (default name shown):
AUREY_ONECLAW_BOOTSTRAP_API_KEY=

# Override the bootstrap env var name (optional):
# AUREY_ONECLAW_API_KEY_SECRET_SOURCE=AUREY_ONECLAW_BOOTSTRAP_API_KEY

# Default Deep Agents model when `POST /v1/invoke` omits `model`
AUREY_DEEP_AGENT_DEFAULT_MODEL=openai:gpt-4o-mini
# Optional: checksum wallet always included in the deep agent system prompt (operator long-term context).
# AUREY_DEEP_AGENT_WALLET_ADDRESS=0x…
OPENAI_API_KEY=sk-
# 1Claw vault paths and optional plaintext env keys (never commit real secrets).
# For hosted deployments you may set API keys directly via env; when set, they take precedence
# over the vault path for the same provider.
# The Alchemy key backs REST reads, JSON-RPC (including `tx_execute` broadcast), and URLs such as:
# https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_KEY}
# https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_KEY}
# AUREY_ALCHEMY_API_KEY=
# AUREY_ALCHEMY_API_SECRET_PATH=
# AUREY_LIFI_API_KEY=
# AUREY_LIFI_API_SECRET_PATH=
# EVM signing: vault-backed key (default) vs future unified 1Claw intents signing.
# AUREY_EVM_SIGNING_MODE=vault_key
# AUREY_EVM_SIGNING_MODE=oneclaw_intents
# Vault path for signing key material - required only when AUREY_EVM_SIGNING_MODE=vault_key.
# AUREY_WALLET_SIGNING_KEY_SECRET_PATH=
# AUREY_TELEGRAM_BOT_TOKEN=
# AUREY_TELEGRAM_BOT_TOKEN_SECRET_PATH=
# Optional: restrict who may message the bot (comma or whitespace separated numeric chat ids).
# Private chat id equals your Telegram user id; groups/supergroups use negative ids (often -100…).
# Omit or leave empty to allow any chat.
# AUREY_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890

# LangGraph Postgres checkpointer (production). Railway: set DATABASE_URL to ${{Postgres.DATABASE_URL}}.
# Alternatively: AUREY_DATABASE_URL=
# DATABASE_URL=

# Evaluation / local debugging: structured tool boundaries in stderr (invoke path only when set).
# AUREY_AGENT_TRACE=info
# AUREY_AGENT_TRACE=debug

# LangSmith / LangChain tracing (optional) — same baseline as the observability quickstart:
# LANGSMITH_TRACING, LANGSMITH_API_KEY, and optionally LANGSMITH_PROJECT.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=aurey
# LANGSMITH_ENDPOINT=   # only if required (self-hosted LangSmith or non-default API host); omit for hosted US cloud
