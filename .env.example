# Aurey — sample environment (copy to `.env` and fill in).
# Pydantic loads `AUREY_*`; see `src/aurey/settings/__init__.py`.
#
# Cloud-first layout:
#   - `AUREY_PLT_*` — platform / hosted-operator credentials (1Claw app, template).
#   - `AUREY_OCV_*` — per-deployment operator runtime (vault + agent API key for SecretStore).

# -----------------------------------------------------------------------------
# Operator runtime (required for `bootstrap_aurey_service_state` / production HTTP)
# -----------------------------------------------------------------------------
AUREY_OCV_VAULT_ID=
# API key value lives in the env var *named* below (default name shown):
AUREY_OCV_AGENT_API_KEY=

# Optional: override which env var holds the operator agent key
# AUREY_OCV_AGENT_API_KEY_SECRET_SOURCE=AUREY_OCV_AGENT_API_KEY

# Optional: operator agent id for hosted JWT exchange (`agt_…`)
# AUREY_OCV_AGENT_ID=

# Default 1Claw API host for vault/agent traffic (omit for https://api.1claw.xyz)
# AUREY_OCV_ONECLAW_BASE_URL=https://api.1claw.xyz

# Scope for POST /v1/auth/delegated-token when signing as hosted user agents (confirm with 1Claw)
# AUREY_ONECLAW_DELEGATED_TOKEN_SCOPE=intents:sign

# -----------------------------------------------------------------------------
# Platform (1Claw ``plt_`` — user provisioning; read when cloud onboarding is enabled)
# -----------------------------------------------------------------------------
# AUREY_PLT_APP_ID=
# AUREY_PLT_TEMPLATE_ID=
# Name of an env var that holds the platform app API key
# AUREY_PLT_APP_API_KEY_SECRET_SOURCE=AUREY_PLT_APP_API_KEY
# AUREY_PLT_APP_API_KEY=
# AUREY_PLT_ONECLAW_BASE_URL=https://api.1claw.xyz

# OIDC subject tokens (RS256) + JWKS — required together with ``DATABASE_URL`` for Telegram ``/start`` onboarding
# AUREY_OIDC_ISSUER=https://your-public-host
# AUREY_SUBJECT_TOKEN_AUDIENCE=          # optional; defaults to AUREY_PLT_APP_ID
# AUREY_SUBJECT_TOKEN_TTL_SECONDS=300
# Background claim polling cadence (seconds) when cloud onboarding is enabled
# AUREY_CLAIM_POLL_INTERVAL_SECONDS=30
# AUREY_OIDC_RSA_PRIVATE_KEY_PEM_SECRET_SOURCE=AUREY_OIDC_RSA_PRIVATE_KEY_PEM
# AUREY_OIDC_RSA_PRIVATE_KEY_PEM=

# After deploy: ``uv run alembic upgrade head`` (install ``aurey[api]`` for Alembic).

# Default Deep Agents model when `POST /v1/invoke` omits `model`
AUREY_DEEP_AGENT_DEFAULT_MODEL=openai:gpt-4o-mini
# Optional: checksum wallet always included in the deep agent system prompt (operator long-term context).
# AUREY_DEEP_AGENT_WALLET_ADDRESS=0x…
OPENAI_API_KEY=sk-
# 1Claw vault paths only (never inline secrets).
# The Alchemy key backs REST reads, JSON-RPC (including `tx_execute` broadcast), and URLs such as:
# https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_KEY}
# https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_KEY}
# AUREY_ALCHEMY_API_SECRET_PATH=
# AUREY_LIFI_API_SECRET_PATH=
# EVM signing: vault-backed key (default) vs future unified 1Claw intents signing.
# AUREY_EVM_SIGNING_MODE=vault_key
# AUREY_EVM_SIGNING_MODE=oneclaw_intents
# Vault path for signing key material - required only when AUREY_EVM_SIGNING_MODE=vault_key.
# AUREY_WALLET_SIGNING_KEY_SECRET_PATH=
# AUREY_TELEGRAM_BOT_TOKEN_SECRET_PATH=
# Optional: restrict who may message the bot (comma or whitespace separated numeric chat ids).
# Private chat id equals your Telegram user id; groups/supergroups use negative ids (often -100…).
# Omit or leave empty to allow any chat.
# AUREY_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890

# LangGraph Postgres checkpointer (production). Railway: set DATABASE_URL to ${{Postgres.DATABASE_URL}}.
# Alternatively: AUREY_DATABASE_URL=
# DATABASE_URL=

# Evaluation / local debugging: structured tool boundaries in stderr (invoke path only when set).
# AUREY_AGENT_TRACE=info
# AUREY_AGENT_TRACE=debug

# LangSmith / LangChain tracing (optional) — same baseline as the observability quickstart:
# LANGSMITH_TRACING, LANGSMITH_API_KEY, and optionally LANGSMITH_PROJECT.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=aurey
# LANGSMITH_ENDPOINT=   # only if required (self-hosted LangSmith or non-default API host); omit for hosted US cloud
