# =============================================================================
# Hosted Aurey — sample environment
# Copy to `.env`, fill in values, never commit real secrets.
#
# Quick map:
#   DATABASE_URL          → Postgres you run (or Railway, etc.)
#   plt_ key              → 1Claw *Platform* API (provision users / templates)
#   bootstrap + vault id  → 1Claw *operator* account (same product as README;
#                           not the Platform key)
#   OPENAI + Alchemy      → model + chain reads / tx broadcast
#   Telegram              → bot token from @BotFather; your user id from @userinfobot
#
# Docs: https://docs.1claw.xyz (Platform API), https://alchemy.com, https://platform.openai.com
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres — LangGraph checkpoints + `hosted_platform_users` (Telegram provisioning).
#
# What: Connection URL for one database used by the app and Alembic migrations.
# How:  Create a DB (Docker, Railway Postgres, etc.). For psycopg3 + Alembic, use:
#       postgresql+psycopg://USER:PASSWORD@127.0.0.1:5433/DATABASE_NAME
#       (Aurey rewrites ``postgresql+psycopg://`` → ``postgresql://`` for LangGraph's
#       Postgres checkpointer only — keep one DATABASE_URL for app + migrations.)
# Run:  `uv run alembic upgrade head` with DATABASE_URL exported.
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Hosted mode — must be true for this product; requires DATABASE_URL above.
# -----------------------------------------------------------------------------
AUREY_HOSTED_PLATFORM_ENABLED=true

# Required for reliable claim detection: GET /v1/platform/apps/{id}/users (list match by
# connection_id). Without it, refresh falls back to GET /v1/platform/connections/{id}, which
# may return 404 on some tenants.
# AUREY_PLATFORM_APP_ID=

# Synthetic email domain for 1Claw Platform `users/upsert` from Telegram.
# What: Each Telegram user is upserted as  tg_<telegram_user_id>@<this domain>
#       (the address is synthetic; only used as a stable Platform user id).
# How:  Any stable DNS-style string you control is fine; default is fine for dev.
AUREY_HOSTED_SYNTHETIC_EMAIL_DOMAIN=hosted-aurey.local

# -----------------------------------------------------------------------------
# 1Claw Platform API — provisioning (NOT the same as bootstrap below).
#
# AUREY_PLATFORM_API_KEY
#   What: Platform API key (often prefix `plt_`) for your registered app.
#   How:  1Claw dashboard → Platform / developer flow, or
#         POST https://api.1claw.xyz/v1/platform/apps per 1Claw docs.
# AUREY_PLATFORM_TEMPLATE_ID
# Optional: AUREY_PLATFORM_CLAIM_RETURN_TO (reissue-claim return_to callback)
#   What: UUID/string of the bootstrap template (vault + agent + policies sketch).
#   How:  Create template via Platform API or console; copy template id from response.
#
# See: https://docs.1claw.xyz/docs/guides/platform-api
# -----------------------------------------------------------------------------
AUREY_PLATFORM_API_KEY=
AUREY_PLATFORM_TEMPLATE_ID=

# HTTP admin — Bearer token for POST /v1/hosted/sync-wallet (backfill wallet_address
# from 1Claw signing-keys for a given telegram_user_id). One deployment-wide secret;
# if unset, the route returns 503 (disabled).
# AUREY_HOSTED_HTTP_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# 1Claw operator vault + API key — used by the wired `OneClawSecretStore` and
# HTTP client (vault path fallbacks, intents client, etc.).
#
# AUREY_ONECLAW_VAULT_ID
#   What: Vault id string for the operator deployment (from 1Claw UI).
#   How:  Dashboard → vaults → copy id (not the Platform app id).
#
# AUREY_ONECLAW_BOOTSTRAP_API_KEY
#   What: API key for your 1Claw org/agent that can use that vault — the key
#          you get when you create the deployment agent (README “bootstrap” key).
#   How:  Same flow as classic Aurey / 1Claw quickstart: NOT the `plt_` Platform key.
#
# AUREY_ONECLAW_AGENT_ID (optional)
#   What: If set, secret reads use POST /v1/auth/agent-token(agent_id, api_key).
#   How:  Agent id string from 1Claw for the agent tied to that vault.
#
# Hosted Telegram users — Platform bootstrap may return ``summary.agent_api_key`` (``ocv_``).
# Aurey dual-writes that secret when configured:
#   • PUT /v1/vaults/{vault_id}/secrets/{prefix}/{user_agent_id}/agent_api_key
#       — Bearer AUREY_ONECLAW_HUMAN_API_TOKEN (Human API JWT)
#   • Fernet ciphertext into Postgres agent_api_key_encrypted — AUREY_HOSTED_SECRETS_MASTER_KEY
# Resolution order at signing time: vault (secrets:resolve with bootstrap key) → ciphertext → legacy plaintext agent_api_key → deployment bootstrap api_key.
# Optional overrides:
# AUREY_HOSTED_AGENT_API_KEY_VAULT_ID=          # defaults to AUREY_ONECLAW_VAULT_ID
# AUREY_HOSTED_AGENT_API_KEY_PATH_PREFIX=hosted/agents
# AUREY_HOSTED_SECRETS_MASTER_KEY=
# AUREY_ONECLAW_HUMAN_API_TOKEN=
# -----------------------------------------------------------------------------
AUREY_ONECLAW_VAULT_ID=
AUREY_ONECLAW_BOOTSTRAP_API_KEY=
# AUREY_ONECLAW_AGENT_ID=

# -----------------------------------------------------------------------------
# Delegated signing (hosted users) — POST /v1/auth/delegated-token
#
# AUREY_OPERATOR_AGENT_API_KEY (optional)
#   What: Separate *actor* credential if 1Claw requires it for delegation.
#   How:  Only if you were given a distinct key; otherwise leave unset — the app
#         will use AUREY_ONECLAW_BOOTSTRAP_API_KEY as the actor.
#
# AUREY_ONECLAW_DELEGATED_TOKEN_SCOPE
#   What: Scope string 1Claw expects for delegated-token exchange.
#   How:  Confirm in 1Claw Platform / security docs; placeholder may need changing.
# -----------------------------------------------------------------------------
# AUREY_OPERATOR_AGENT_API_KEY=
AUREY_ONECLAW_DELEGATED_TOKEN_SCOPE=1claw:intents:delegated

# -----------------------------------------------------------------------------
# EVM + model — transaction signing mode and LLM provider.
#
# AUREY_EVM_SIGNING_MODE=oneclaw_intents  → user keys via 1Claw intents + delegation;
#   not raw private keys in Aurey.
#
# LLM routing (defaults: Shroud proxy):
#   AUREY_LLM_PROXY=shroud  → POST https://shroud.1claw.xyz/v1/chat/completions with
#       X-Shroud-Agent-Key, X-Shroud-Provider (see https://docs.1claw.xyz/docs/guides/shroud).
#       Standalone: set AUREY_ONECLAW_AGENT_ID plus operator/agent key (delegated actor or bootstrap).
#       Hosted Telegram: per-user ocv_ from vault/DB automatically.
#   OPENAI_API_KEY — optional plaintext OpenAI key (X-Shroud-Api-Key to Shroud) or omit and use
#       user vault providers/openai/api-key after Platform template enables Shroud on the agent.
#   AUREY_OPENAI_API_SECRET_PATH — optional vault path → sent as vault://{vault}/{path} header.
#
# Local / debugging without Shroud:
#   AUREY_LLM_PROXY=direct  → requires OPENAI_API_KEY (straight to api.openai.com).
#
# AUREY_DEEP_AGENT_DEFAULT_MODEL — provider:model, e.g. openai:gpt-4o-mini
# -----------------------------------------------------------------------------
AUREY_EVM_SIGNING_MODE=oneclaw_intents
AUREY_LLM_PROXY=shroud
# AUREY_SHROUD_BASE_URL=https://shroud.1claw.xyz
AUREY_DEEP_AGENT_DEFAULT_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=
# AUREY_OPENAI_API_SECRET_PATH=


# -----------------------------------------------------------------------------
# Alchemy — JSON-RPC + Data/Prices APIs used by graph tools and tx broadcast.
# How: https://dashboard.alchemy.com → create app → copy API key.
# -----------------------------------------------------------------------------
AUREY_ALCHEMY_API_KEY=

# -----------------------------------------------------------------------------
# LiFi (optional) — better rate limits / routing for LiFi-backed tools.
# How: https://li.quest (integrator/API key docs); omit for unauthenticated calls.
# -----------------------------------------------------------------------------
# AUREY_LIFI_API_KEY=

# -----------------------------------------------------------------------------
# Telegram bot
#
# AUREY_TELEGRAM_BOT_TOKEN
#   What: HTTP API token string from BotFather when you create the bot.
#   How:  Telegram → @BotFather → /newbot or /token → copy token.
#
# AUREY_TELEGRAM_ALLOWED_CHAT_IDS (optional)
#   What: Restrict which chats may use the bot; numeric chat ids as above.
#   How:  Private chat id often equals user id; groups are negative (@userinfobot).
# -----------------------------------------------------------------------------
AUREY_TELEGRAM_BOT_TOKEN=
# AUREY_TELEGRAM_ALLOWED_CHAT_IDS=

# =============================================================================
# Rare / troubleshooting — only if you intentionally use vault paths or rename envs
# =============================================================================
#
# If the bootstrap API key lives under a differently named env var:
# AUREY_ONECLAW_API_KEY_SECRET_SOURCE=AUREY_ONECLAW_BOOTSTRAP_API_KEY
#
# If the optional operator actor key is read from another env **name**:
# AUREY_OPERATOR_AGENT_API_KEY_SECRET_SOURCE=AUREY_OPERATOR_AGENT_API_KEY
#
# If you do NOT set plaintext Alchemy/LiFi/Telegram keys above, you can resolve
# them from the 1Claw vault paths below (matching paths you configured in UI):
# AUREY_ALCHEMY_API_SECRET_PATH=
# AUREY_LIFI_API_SECRET_PATH=
# AUREY_TELEGRAM_BOT_TOKEN_SECRET_PATH=

# -----------------------------------------------------------------------------
# Debugging & traces
# -----------------------------------------------------------------------------
# App logs (Railway / stdout):
#   AUREY_AGENT_TRACE=minimal  — prod-friendly: tool names, sizes, errors (no 2k payloads)
#   AUREY_AGENT_TRACE=info     — eval / support: tool I/O clipped to 2000 chars
#   AUREY_AGENT_TRACE=debug    — local only: all nodes + LLM tokens (very verbose)
#   (unset or off)             — no aurey.agent.trace callback; aurey.turn still logs turns
#
# Full run traces (LangSmith UI, not log volume):
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=aurey-hosted-beta
