# HTTP service + Telegram Mini App static build (Node + Python/uv).
# Used by Railway when railway.http.toml sets build.builder = DOCKERFILE.

FROM node:22-bookworm-slim AS miniapp_builder

WORKDIR /src
COPY miniapp/package.json miniapp/package-lock.json ./miniapp/
RUN cd miniapp && npm ci
COPY miniapp/ ./miniapp/
RUN cd miniapp && npm run build

FROM python:3.12-slim-bookworm

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:0.7.8 /uv /usr/local/bin/uv

COPY pyproject.toml uv.lock README.md run_http.py ./
COPY src ./src

RUN uv sync --frozen --no-dev --extra api

COPY --from=miniapp_builder /src/miniapp/dist ./miniapp/dist

ENV PATH="/app/.venv/bin:${PATH}"

EXPOSE 8000

CMD ["sh", "-c", "exec uv run python run_http.py --host 0.0.0.0 --port ${PORT:-8000}"]
