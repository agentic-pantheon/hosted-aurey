# Exclude from Cursor indexing/context (heavy, generated, or sensitive)

# Virtual environments
.venv/
venv/
ENV/

# Python bytecode and packages
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.egg

# Caches & test artifacts
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

# Environment and secrets (never send to indexing)
.env
.env.*
!.env.example

# OS / IDE
.DS_Store

# Logs
*.log
